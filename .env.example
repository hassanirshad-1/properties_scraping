# ── AI Image Analysis (OpenAI-compatible API) ──
AGENTROUTER_BASE_URL=https://api.swiftrouter.com/v1/
AGENTROUTER_API_KEY=your-api-key-here
AGENTROUTER_MODEL_NAME=kimi-k2.5

# ── Bawab Database (Postgres) ──
DATABASE_URL=postgres://user:password@host:5432/bawab

# ── Auto-Scheduler ──
ENABLE_SCHEDULER=true
SCRAPE_INTERVAL_HOURS=6
SCRAPE_CITY=cairo
SCRAPE_LIMIT=100

# ── Server ──
PORT=8000
